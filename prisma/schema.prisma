// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR
  ORCHESTRATOR
  CONTROLLER_APPROVER
  CLERK_SUBMITTER
  ANALYST
}

enum StatusValue {
  pending
  active
  suspended
  inactive
}

enum FinancialRecordType {
  INCOME
  EXPENSE
}

enum FinancialRecordStatus {
  PENDING
  APPROVED
  REJECTED
  DELETED
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  timezone         String?
  passwordHash     String?
  refreshTokenHash String?
  lastLoginAt      DateTime?
  failedLoginAttempts Int   @default(0)
  lockedUntil      DateTime?
  sessionVersion   Int      @default(1)
  role             Role     @default(ANALYST)
  roleId           Int      @default(4)
  status           StatusValue @default(active)
  isActive         Boolean  @default(true)
  inviteTokenJti   String?
  inviteExpiresAt  DateTime?
  department       String?
  reportingManager String?
  createdRecords   FinancialRecord[] @relation("CreatedFinancialRecords")
  approvedRecords  FinancialRecord[] @relation("ApprovedFinancialRecords")
  deletedRecords   FinancialRecord[] @relation("DeletedFinancialRecords")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FinancialRecord {
  id          Int                 @id @default(autoincrement())
  createdBy   Int
  approvedBy  Int?
  deletedBy   Int?
  amount      Decimal             @db.Decimal(14, 2)
  type        FinancialRecordType
  status      FinancialRecordStatus @default(PENDING)
  category    String
  date        DateTime
  notes       String?
  description String?
  approvedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  creator  User  @relation("CreatedFinancialRecords", fields: [createdBy], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovedFinancialRecords", fields: [approvedBy], references: [id], onDelete: SetNull)
  deleter  User? @relation("DeletedFinancialRecords", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([approvedBy])
  @@index([deletedBy])
  @@index([createdBy, date])
  @@index([createdBy, category])
  @@index([createdBy, type])
  @@index([createdBy, type, category, date])
}
