# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/finance_dashboard
DIRECT_URL=postgresql://postgres:postgres@postgres:5432/finance_dashboard
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600
ACCESS_TOKEN_SECRET=change-me-access-secret
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_TTL=604800
INVITE_TOKEN_EXPIRATION=48h
INVITE_EXPIRATION_HOURS=48
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Frontend
FRONTEND_BASE_URL=http://localhost:3000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=Finance Dashboard <your-email@gmail.com>

# Server
PORT=3000
NODE_ENV=production

# Dashboard Cache
DASHBOARD_CACHE_ACTIVE_TTL_MS=300000
DASHBOARD_CACHE_HISTORICAL_TTL_MS=900000
DASHBOARD_CACHE_VERSION_TTL_MS=2592000000

# Optional
SEED_ON_BOOT=false
